{
  "name": "sentinel-web-oracle",
  "version": "0.1.0",
  "description": "Agentic crypto threat intelligence powered by Bright Data live web infrastructure",
  "main": "dist/index.js",
  "scripts": {
    "dev:backend": "ts-node src/index.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "mcp": "ts-node src/mcp/server.ts",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "tsc",
    "build": "npm run build:backend && npm run build:frontend",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "bright-data",
    "ai-agent",
    "mcp",
    "crypto",
    "threat-intelligence",
    "web-scraping",
    "security"
  ],
  "author": "NullSentinel",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.6.0",
    "concurrently": "^10.0.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "groq-sdk": "^1.2.1",
    "sqlite3": "^6.0.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/sqlite3": "^3.1.11",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
